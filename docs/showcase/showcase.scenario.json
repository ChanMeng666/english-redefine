      ]
    },
    {
      "label": "author-card",
      "viewport": "desktop",
      "before": [
        { "action": "goto", "url": "https://english-redefine.chanmeng-dev.workers.dev/" },
        { "action": "wait", "ms": 1500 },
        { "action": "scroll", "by": 400 },
        { "action": "wait", "ms": 500 }
      ]
    },
    {
      "label": "mobile-hero",
      "viewport": "mobile",
      "before": [
        { "action": "goto", "url": "https://english-redefine.chanmeng-dev.workers.dev/" },
        { "action": "wait", "ms": 1500 }
      ]
    }
  ],
  "demo": {
    "size": { "width": 1280, "height": 800 },
    "steps": [
      { "action": "goto", "url": "https://english-redefine.chanmeng-dev.workers.dev/" },
      { "action": "wait", "ms": 1500 },
